
:root{
    --color: #c36060;
    --color1: #009688;
    --color2: #DD7230; /* brand orange */
    --color3: #f7e5d2; /* light warm background */

    /* Additional theme tokens */
    --brand: var(--color2);
    --accent: #D9B38C;
    --dark: #3a170a; /* warm dark brown for text/backgrounds */
    --bg: var(--color3);
    --card-bg: #fff7f0; /* soft off-white warm card background */
    --text: var(--dark);
}

*{
    margin: 0;
    padding: 0;
    font-family: 'Poppins', sans-serif;
    box-sizing: border-box;
}


html, body {
    margin: 0;
    padding: 0;
    max-width: 100%;
    font-family: 'Poppins', sans-serif;

    background-color: var(--bg); /* warm site background */
}

body { color: var(--text); }
/* ======================================================== Hero ========================================================================================== */
.banner{
    width: 100%;
    height: 100vh;
    background-image: linear-gradient(rgba(0, 0, 0, 0.7),rgba(0,0,0,0.7)),url(https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?q=80&w=1740&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D);
    background-size: cover;
    background-position: center;    
}

.navbar {
    position: fixed;   
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;   
}
.navbar ul {
    display: flex;
    align-items: center;
    justify-content: flex-end; 
    gap: 28px;                  
    margin: 0;
    padding: 35px 40px;       
    width: auto;        
    background-color: #DD7230;       
    height: 15vh;        /* makes it taller */
    padding: 40px 50px;
}

.nav-color {
    color: var(--dark);
    
}

.navbar ul li{
    list-style: none;
    display: inline-block;
    margin: 0 20px;    
    position: relative;
}

.navbar ul li.donate a{
    background-color: var(--card-bg);
    color: var(--brand);
    padding: 10px 22px;
    border-radius: 5px;
    font-weight: bold;
    transition: all 0.3s ease;
}

.navbar ul li.donate a:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
}

.navbar ul li.donate::after {
    display: none;
}

.navbar ul li a{
    text-decoration: none;
    color: white;
    text-transform: uppercase;     
}

.navbar ul li::after{
    content: '';
    height: 3px;
    width: 0;
    background: #D9B38C;;
    position: absolute;
    left: 0;
    bottom: -10px;
    transition: width 0.3s ease;
}

.navbar ul li:hover::after{
    width: 100%;
}

.content{
    width: 100%;
    position: absolute;
 
    top: 65%;
    transform: translateY(-50%);
    text-align: center;
    color: #fff;     
}


.content h1{
    font-size: 70px;
    margin-top: 30px;
    cursor: default;    
}

.content p{
    margin: 20px auto;
    font-weight: 100;
    line-height: 25px;    
    cursor: default; 
}

button{
    width: 200px;
    padding: 15px 0;
    text-align: center;
    margin: 20px 10px;
    border-radius: 25px;
    font-weight: bold;
    color: #fff;
    cursor: pointer;
    background: transparent;
    border: 2px solid #DD7230;
    position: relative;
    overflow: hidden;
}

button span{
    background: #D9B38C; /* ICON BACK */
    height: 100%;
    width: 0;
    border-radius: 25px;
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: -1;
    transition: width 0.3s ease;
}

.icon{
    background-color: #000;
}
button:hover span{
    width: 100%;
}

button:hover{
    border: none;
   
}

/* ANIMATION*/

.content h1,
.content p,
.content button {
    opacity: 0;
    transform: translateY(8px); 
    animation: fadeUp 0.5s ease forwards
} 


.content h1 {
    animation-delay: 0.9s;
}

.content p {
    animation-delay: 0.9s;
}

.content button:nth-of-type(1) {
    animation-delay: 0.9s;
}

.content button:nth-of-type(2) {
    animation-delay: 0.9s;
}

/* Animation */
@keyframes fadeUp {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}



/* ================================================================== COUNTER =================================================================== */

.fadeUp{
    animation: fadeUp both;
    animation-timeline: view();
}

.timeline-item:nth-child(1){
    animation-range: entry 20% cover 40%;
}

.timeline-item:nth-child(2){
    animation-range: entry 40% cover 60%;
}

.timeline-item:nth-child(2){
    animation-range: entry 60% cover 80%;
}

@keyframes fadeUp{
    from {
        opacity: 0;
        transform: translateY(10px) scale(0.5);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

/* Timeline Layout */
/* Timeline Section */ 
.timeline-section{ 
    position: relative; 
    background-color: var(--dark); /* warm dark background for timeline */
    color: var(--card-bg);
    width: 100%;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

      /* Center white line */ 
.timeline-line { 
    position: absolute; 
    left: 50%; 
    top: 0; 
    width: 3px; 
    height: 100%; 
    background: var(--accent); 
    transform: translateX(-50%); 
    z-index: 1; }

/* Timeline items */
.timeline-item {
  position: relative;
  margin: 170px 0;
}

/* Content boxes */
.timeline-content {
    width: 40%;
    background: var(--dark);
    padding: 20px 30px;
    border-radius: 10px;
    position: relative;
    z-index: 2;
}

/* Left/right alignment of content */
.timeline-item.left .timeline-content {
  margin-right: 50%;
  text-align: right;

}

.timeline-item.right .timeline-content {
  margin-left: 50%;
  text-align: left;
}

/* Text styling */
.timeline-content h4 {
  color: #89B6A5;
  font-size: 14px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.timeline-content h2 {
  font-size: 42px;
  color: #fff;
  margin: 10px 0;
}

.timeline-content p {
  color: #fff;
  font-size: 17px;
  font-weight: 800;
}


.timeline-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    border: 3px solid var(--accent);
    background: #89B6A5;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    text-decoration: none;
    overflow: hidden;
    z-index: 2;
    text-decoration: none;
}

a.timeline-icon {
    text-decoration: none !important;
    outline: none !important;
}



.timeline-icon span {
    font-size: 32px;
   
    align-items: center;        /* center vertically */
   justify-content: center;
    display: flex;
    width: 100%;                /* fill the circle container */
   height: 100%;  
-webkit-text-fill-color: #fff; 
    font-variation-settings: 'FILL' 1, 'wght' 400;
}



/* Horizontal positioning opposite content */
.timeline-item.left .timeline-icon {
  left: calc(50% + 90px);   /* right of center line */
}

.timeline-item.right .timeline-icon {
  right: calc(50% + 90px);  /* left of center line */
}

/* Fade-up animation */
.fadeUp {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.6s ease;
}

.fadeUp.show {
  opacity: 1;
  transform: translateY(0);
}


