/* ========================Footer Base =================*/


.site-footer {
 background: radial-gradient(circle at top, #5a2400, #2b1200);
 color: var(--card-bg);
 padding: 80px 80px 30px;

 margin-top: -30px;
 border-top: 1px solid rgba(255,255,255,0.08);

 position: relative;
 z-index: 5;
}


.site-footer-container {
 display: flex;
 justify-content: space-between;
 align-items: flex-start;
 flex-wrap: wrap;
}


/* LEFT */
.site-footer-left {
 max-width: 50%;
}


.site-footer-links {
 display: grid;
 grid-template-columns: repeat(2, auto);
 gap: 15px 50px;
 margin-bottom: 30px;
}


.site-footer-links a {
 color: white;
 text-decoration: none;
 font-weight: bold;
 text-transform: uppercase;
 font-size: 14px;
 transition: all 0.3s ease;
}


.site-footer-links a:hover {
 opacity: 0.7;
}


/* RIGHT */
.site-footer-right {
 text-align: right;
}



/* BOTTOM */
.site-footer-bottom {
 margin-top: 50px;
 text-align: center;
 font-size: 14px;
 opacity: 0.8;
}


.site-footer-bottom a {
 color: white;
 text-decoration: none;
 transition: all 0.3s ease;
}


.site-footer-bottom a:hover {
 text-decoration: underline;
}


/* MOBILE */
@media (max-width: 768px) {
 .site-footer-container {
   flex-direction: column;
   gap: 40px;
 }


 .site-footer-left,
 .site-footer-right {
   max-width: 100%;
   text-align: center;
 }


 .site-footer-social-icons a {
   margin: 0 10px;
 }
}

/* -------------------------------------------------------------------------- */
/* Responsive menu rules merged from css/menu.css (kept here for single-file)  */
/* -------------------------------------------------------------------------- */
.checkbtn {
    font-size: 30px;
    color: var(--dark);
    cursor: pointer;
    display: none; 
}

#check {
    display: none; 
}


@media (max-width: 858px) {

    .checkbtn {
        display: block;
        font-size: 28px;
        color: #DD7230;
        padding: 20px;
    }

    .navbar ul {
        position: fixed;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100vh;
        background: #DD7230;

        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        padding: 0;        /* reset desktop padding */
        margin: 0;         /* reset any margin */
        gap: 30px;

        transition: left 0.4s ease;
        box-sizing: border-box;

    }

    .navbar ul li {
        width: 70%;
        text-align: center;
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.4);
    }

    .navbar ul li:last-child {
        border-bottom: none; /* removes line under last item */
    }


    .navbar ul li a {
        font-size: 22px;
        font-weight: 600;
    }

    #check:checked ~ ul {
        left: 0;
    }
}




/*================= SUGGEST =============*/


.container-submit {

   background: var(--card-bg); 
   box-shadow: 0 0 15px rgba(0,0,0,0.08);
    width: 100%; 
    max-width: 1300px; 
    margin: 0 auto; 
    margin-top: 105px;
    padding: 40px 40px; 

}


/* Header */
.header-row {
   flex-direction: column;
   align-items: flex-start;
   gap: 6px;
   cursor: default;
}


.header-row h1 {
   font-size: 50px;
   margin: 0;
    color: var(--dark);
    margin-left: 25px;
    margin-bottom: 20px;
     margin-top: auto;
    text-align: center;
    cursor: default;
}
.header-row h1::after {
    content: "";
    display: block;
    height: 4px; 
    width: 100%;
    margin: 5px auto 0 auto;
    background: linear-gradient(90deg, #DD7230, #D9B38C); 
    border-radius: 2px; 
    max-width: 430px;
}

/* Form layout */
.form-row {
   display: flex;
   gap: 24px;
   margin-top: 22px;
}


.form-group {
   flex: 1;
   display: flex;
   flex-direction: column;
}


.form-group.full {
   margin-top: 22px;
   font-size: 17px;
}


/* Inputs */
label {
   font-weight: bold;
   margin-bottom: 6px;
   font-family: 'Courier New', Courier, monospace;
}


input, textarea {
   padding: 12px;
   font-size: 16px;
   border: 2px solid #ccc;
}


input:focus, textarea:focus {
   outline: none;
    border-color: var(--dark);
}


/* Submit */
.submit-btn {
   margin-top: 32px;
   background: linear-gradient(90deg, #DD7230, #D9B38C);
   color: white;
   padding: 14px;
   font-size: 16px;
   border-radius: 12px;
   border: none;
   cursor: pointer;
   font-weight: 600;
   transition: all 0.3s ease;
}


.submit-btn:hover {
   transform: translateY(-2px);
   box-shadow: 0 6px 15px rgba(220, 180, 134, 0.942);
}


#message {
  margin: 20px 0;
  padding: 12px 16px;
  border-radius: 10px;
  background: #eaf7ea;
  color: green;
  font-weight: 600;
  display: none; 
}


select {
   padding: 12px;
   font-size: 15px;
   border-radius: 10px;
   border: 1px solid #ccc;
   background: white;
}
textarea {
   min-height: 180px;
   resize: vertical;
   line-height: 1.6;
}


.form-group.category {
   max-width: 180px;
   margin-top: 15px;
}


.form-group.category select {
   width: 100%;
   padding: 8px 10px;
   font-size: 14px;
   border-radius: 20px;
   background-color: white;
   border: 1px solid #bbb;
}


.form-group.category select:focus {
    background-color: white;
    border-color: var(--dark);
   outline: none;
}
.form-group.category option {
    background-color: white;
    color: var(--dark);
}


.form-group.category label {
   font-size: 13px;
   margin-bottom: 4px;
}

/* Checkbox grid for multi-select categories used on the training form */
.checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
}
.checkbox-grid label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
}

/* Small layout helper for the back link/button inside form rows */
.form-row .resource-btn {
    margin-left: 12px;
    display: inline-block;
    text-decoration: none;
}

