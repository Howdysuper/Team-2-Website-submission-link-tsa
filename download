/* ================= TRAINING PAGE ================= */

.training-section {
    background-color: #fddfc0;
    margin-top: 100px;
}

.container-training {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
}

.section-title {
    color: #000;
    font-size: 40px;
    text-align: center;
    margin-bottom: 10px;
    transition: all 0.3s ease;
}

.section-title::after {
    content: "";
    display: block;
    height: 4px;
    width: 200px;
    margin: 5px auto 0 auto;
    background: linear-gradient(90deg, #C85A1C, #DD7230);
    border-radius: 2px;
}

.section-title:hover {
    color: #DD7230;
    transform: translateY(-2px);
}

.training-intro {
    text-align: center;
    margin-bottom: 30px;
    font-size: 16px;
    line-height: 1.6;
    color: #333;
}

.training-overview {
    background-color: #f5f5f5;
    padding: 30px;
    border-radius: 10px;
    margin-bottom: 40px;
}

.training-overview h3 {
    color: #C85A1C;
    margin-bottom: 15px;
    font-size: 24px;
    transition: all 0.3s ease;
    cursor: default;
}

.training-overview h3:hover {
    color: #DD7230;
    transform: translateX(5px);
}

.training-overview p {
    line-height: 1.8;
    margin-bottom: 15px;
    color: #333;
}

/* Partner Section Heading */
.training-partners-heading {
    color: #C85A1C;
    text-align: center;
    margin-bottom: 30px;
    font-size: 28px;
    transition: all 0.3s ease;
    cursor: default;
}

.training-partners-heading:hover {
    color: #DD7230;
    transform: scale(1.05);
}

/* Partner Cards Grid */
.partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.partner-card {
    background: white;
    border-left: 4px solid #C85A1C;
    padding: 20px;
    border-radius: 5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}

.partner-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
}

.partner-card h4 {
    color: #DD7230;
    margin-bottom: 10px;
    font-size: 18px;
    transition: all 0.3s ease;
}

.partner-card:hover h4 {
    color: #009688;
    transform: translateX(3px);
}

.partner-highlights {
    margin-bottom: 12px;
    font-weight: bold;
    color: #009688;
}

.partner-description {
    line-height: 1.6;
    margin-bottom: 15px;
    color: #333;
}

.partner-focus {
    color: #666;
    font-size: 14px;
}

/* How We Help Section */
.training-help-section {
    background-color: #fef4ed;
    padding: 30px;
    border-radius: 10px;
    margin-bottom: 40px;
}

.training-help-heading {
    color: #C85A1C;
    margin-bottom: 20px;
    font-size: 24px;
    transition: all 0.3s ease;
    cursor: default;
}

.training-help-heading:hover {
    color: #DD7230;
    transform: translateX(5px);
}

.help-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.help-card {
    padding: 15px;
    transition: all 0.3s ease;
}

.help-card:hover {
    background-color: rgba(200, 90, 28, 0.1);
    border-radius: 8px;
    transform: translateY(-3px);
    padding: 15px;
}

.help-icon {
    font-size: 36px;
    color: #C85A1C;
    margin-bottom: 10px;
    transition: all 0.3s ease;
}

.help-card:hover .help-icon {
    color: #DD7230;
    transform: scale(1.15) rotate(5deg);
}

.help-card h4 {
    color: #DD7230;
    font-size: 16px;
    margin-bottom: 10px;
    transition: all 0.3s ease;
}

.help-card:hover h4 {
    color: #009688;
}

.help-card p {
    color: #333;
    line-height: 1.6;
}

/* Categories Section */
.training-categories-heading {
    color: #C85A1C;
    text-align: center;
    margin-bottom: 20px;
    font-size: 28px;
    transition: all 0.3s ease;
    cursor: default;
}

.training-categories-heading:hover {
    color: #DD7230;
    transform: scale(1.05);
}

.categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    margin-bottom: 30px;
}

.category-card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    text-align: center;
    border: 2px solid #E8E8E8;
    transition: all 0.3s ease;
}

.category-card:hover {
    border-color: #DD7230;
    background: linear-gradient(135deg, rgba(221, 114, 48, 0.05), rgba(217, 179, 140, 0.05));
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(221, 114, 48, 0.15);
}

.category-label {
    font-size: 14px;
    color: #009688;
    margin-bottom: 5px;
    text-transform: uppercase;
    font-weight: bold;
    transition: all 0.3s ease;
}

.category-card:hover .category-label {
    color: #DD7230;
}

.category-content {
    color: #000;
    margin: 0;
}


/* CTA Section */
.training-cta {
    background: linear-gradient(135deg, #009688 0%, #00796B 100%);
    color: white;
    padding: 40px;
    border-radius: 10px;
    text-align: center;
    transition: all 0.3s ease;
}

.training-cta:hover {
    box-shadow: 0 8px 25px rgba(0, 150, 136, 0.3);
    transform: translateY(-2px);
}

.training-cta h3 {
    margin-bottom: 15px;
    font-size: 24px;
    color: white;
}

.training-cta p {
    margin-bottom: 20px;
    font-size: 16px;
    line-height: 1.6;
    color: white;
}

.training-cta-btn {
    display: inline-block;
    background-color: #DD7230;
    color: white;
    padding: 12px 30px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s ease;
    border: 2px solid #DD7230;
}

.training-cta-btn:hover {
    background-color: transparent;
    color: #DD7230;
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
}

@media (max-width: 768px) {
    .section-title {
        font-size: 28px;
    }

    .training-overview,
    .training-help-section {
        padding: 20px;
    }

    .partners-grid,
    .categories-grid {
        grid-template-columns: 1fr;
        padding: 0 10px;
        gap: 15px;
    }

    .training-cta {
        padding: 25px;
    }

    .training-cta h3 {
        font-size: 20px;
    }
}

@media (max-width: 768px) {

  .container-submit {
margin: 30px auto;

  }

  .header-row h1 {
    font-size: 32px;           /* 50px was doing too much */
    margin-left: 0;
  }

  .header-row h1::after {
    max-width: 100%;
  }

  .form-row {
    flex-direction: column;    /* stack inputs */
    gap: 16px;
  }

  .form-group.category {
    max-width: 100%;           
  }

  input,
  textarea,
  select {
    font-size: 15px;
    width: 100%;
  }

  .submit-btn {
    font-size: 15px;
    padding: 12px;
  }
}

/* Desktop: 4 partner cards per row */
@media (min-width: 1025px) {
    .partners-grid {
        grid-template-columns: repeat(4, 1fr);
    }
    /* Desktop: 3 help cards per row */
     .help-grid {
        grid-template-columns: repeat(3, 1fr);
    }
    /* Desktop: 3 categories cards per row */
     .categories-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px; 
    }
}